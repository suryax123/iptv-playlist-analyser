{
    "name":  "iptv-playlist-analyzer",
    "version":  "2.0.0",
    "description":  "IPTV Playlist Analyzer \u0026 PDF Converter - Optimized for Render Free Tier",
    "main":  "server.js",
    "scripts":  {
                    "start":  "node server.js",
                    "dev":  "node server.js",
                    "minify":  "npx uglify-js ./public/app.js -o ./public/app.min.js -c -m",
                    "build":  "npm run build:css \u0026\u0026 npm run minify",
                    "build:css":  "tailwindcss -i ./src/input.css -o ./public/tailwind-built.css --minify",
                    "watch:css":  "tailwindcss -i ./src/input.css -o ./public/tailwind-built.css --watch"
                },
    "keywords":  [
                     "iptv",
                     "m3u8",
                     "playlist",
                     "analyzer",
                     "converter"
                 ],
    "author":  "",
    "license":  "MIT",
    "dependencies":  {
                         "axios":  "^1.6.0",
                         "compression":  "^1.7.4",
                         "cors":  "^2.8.5",
                         "express":  "^4.18.2",
                          "express-rate-limit":  "^7.4.1",
                         "helmet":  "^7.1.0",
                         "validator":  "^13.11.0"
                     },
    "engines":  {
                    "node":  "\u003e=18.0.0"
                },
    "devDependencies":  {
                            "tailwindcss":  "^3.4.19"
                        }
}
